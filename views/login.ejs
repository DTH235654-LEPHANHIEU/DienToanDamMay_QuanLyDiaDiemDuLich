<%- include('partials/head') %>

<div class="container h-100 d-flex align-items-center justify-content-center">
    <div class="card border-0 shadow-lg overflow-hidden" style="max-width: 900px; border-radius: 24px;">
        <div class="row g-0">
            <div class="col-md-6 d-none d-md-block">
                <img src="https://picsum.photos/seed/travel-login/600/800" class="w-100 h-100 object-fit-cover" alt="Travel">
            </div>
            <div class="col-md-6 p-5 bg-white">
                <div class="mb-5">
                    <h2 class="fw-bold text-primary">Chào mừng trở lại!</h2>
                    <p class="text-muted">Đăng nhập để quản lý hành trình của bạn.</p>
                </div>
                
                <form id="loginForm" action="/login" method="POST">
                    <div class="mb-4">
                        <label class="form-label small fw-bold">Email</label>
                        <input type="email" name="email" class="form-control form-control-lg bg-light border-0 shadow-none" placeholder="name@example.com" required>
                    </div>
                    <div class="mb-4">
                        <label class="form-label small fw-bold">Mật khẩu</label>
                        <input type="password" name="password" class="form-control form-control-lg bg-light border-0 shadow-none" placeholder="••••••••" required>
                    </div>
                    <div class="d-flex justify-content-between mb-4">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="remember">
                            <label class="form-check-label small" for="remember">Ghi nhớ tôi</label>
                        </div>
                        <a href="#" class="small text-decoration-none">Quên mật khẩu?</a>
                    </div>
                    <div class="d-grid mb-4">
                        <button type="submit" class="btn btn-primary btn-lg fw-bold py-3 rounded-3">Đăng nhập</button>
                    </div>
                    <% if (typeof error !== 'undefined') { %>
                        <div class="alert alert-danger" role="alert">
                            <%= error %>
                        </div>
                    <% } %>
                    <div class="text-center">
                        <p class="small text-muted">Chưa có tài khoản? <a href="/register" class="text-primary fw-bold text-decoration-none">Đăng ký ngay</a></p>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<%- include('partials/scripts') %>
